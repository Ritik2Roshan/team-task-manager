DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=taskmanager_db

# Railway MySQL service variables also work automatically:
# MYSQL_URL=mysql://user:password@host:port/database
# MYSQLHOST=localhost
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=
# MYSQLDATABASE=taskmanager_db

JWT_SECRET=change_me_to_a_long_random_string
PORT=5000
# Optional: max size per file (MB). Default 25.
UPLOAD_MAX_MB=25
# Optional: absolute path for project uploads. Default ./uploads/projects under backend cwd.
# UPLOAD_DIR=C:/data/taskmanager-uploads
